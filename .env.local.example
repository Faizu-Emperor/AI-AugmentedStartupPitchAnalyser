# Copy this file to .env.local and fill in your real key.
# Get a Gemini key: https://aistudio.google.com/apikey

GEMINI_API_KEY=your-gemini-key-here

# ANTHROPIC_API_KEY is no longer required — this app now uses Gemini for both
# extraction and scoring, since Anthropic's API requires a minimum prepaid
# credit balance with no free-calling tier. See README.md for the honesty
# note this decision requires in your project documentation.
